{
  "experiment": {
    "name": "rhpe_boneage_bonet_master_like",
    "mode": "bonet_like",
    "output_root": "outputs",
    "seed": 2026
  },
  "runtime": {
    "device": "cuda:0",
    "allow_cpu_fallback": true,
    "deterministic": false,
    "channels_last": false
  },
  "data": {
    "dataset_root": "dataset",
    "input_size": 500,
    "local_patch_size": 96,
    "max_keypoints": 17,
    "heatmap_sigma_ratio": 0.0,
    "heatmap_sigma_min": 25.0,
    "global_crop_mode": "bbox",
    "global_crop_margin_ratio": 0.0,
    "verify_images": false,
    "normalization": {
      "source": "manual",
      "stats_path": "dataset/train_mean_std.json",
      "mean": 0.0,
      "std": 1.0,
      "resolved_source": "manual"
    }
  },
  "model": {
    "ensemble_mode": "resnet",
    "resnet_name": "resnet18",
    "efficientnet_name": "efficientnet_b0",
    "pretrained": false,
    "branch_mode": "global_only",
    "target_mode": "direct",
    "relative_target_direction": "boneage_minus_chronological",
    "global_dim": 256,
    "heatmap_guidance": {
      "enabled": true
    },
    "cbam": {
      "enabled": false,
      "global_branch": true,
      "local_branch": true
    },
    "metadata": {
      "enabled": true,
      "mode": "mlp",
      "use_gender": true,
      "use_chronological": false,
      "hidden_dim": 32,
      "gender_embedding_dim": 32,
      "chronological_hidden_dim": 16,
      "dropout": 0.0
    },
    "local_branch": {
      "mode": "patch_heatmap",
      "feature_dim": 128,
      "geometry_dim": 64,
      "dropout": 0.2
    },
    "head": {
      "hidden_dim": 256,
      "dropout": 0.25
    }
  },
  "augmentation": {
    "affine_p": 1.0,
    "rotation_limit": 20,
    "translate_limit": 0.2,
    "scale_limit": 0.2,
    "shear_limit": 0,
    "horizontal_flip": true,
    "horizontal_flip_p": 0.5,
    "use_noise": false,
    "noise_std_min": 0.005,
    "noise_std_max": 0.02,
    "noise_p": 0.12,
    "use_blur": false,
    "blur_limit": 3,
    "blur_p": 0.08
  },
  "training": {
    "epochs": 90,
    "batch_size": 20,
    "val_batch_size": 1,
    "test_batch_size": 1,
    "optimizer": "adam",
    "lr": 0.0001,
    "weight_decay": 0.0,
    "momentum": 0.9,
    "scheduler": "plateau",
    "scheduler_factor": 0.1,
    "scheduler_patience": 2,
    "warmup_epochs": 0,
    "warmup_start_factor": 0.2,
    "min_lr": 1e-05,
    "loss": "l1",
    "smooth_l1_beta": 0.5,
    "amp": false,
    "gradient_clip": 0.0,
    "gradient_accumulation_steps": 1,
    "compile": false,
    "compile_mode": "reduce-overhead",
    "best_metric": "mae",
    "resume_checkpoint": null,
    "progress_bar": true,
    "log_interval": 30,
    "eval_interval": 1,
    "save_interval": 1,
    "early_stopping_patience": 0,
    "early_stopping_min_delta": 0.0,
    "workers_override": 4,
    "prefetch_factor": 2,
    "persistent_workers": true,
    "pin_memory": true,
    "scheduler_cooldown": 0
  },
  "debug": {
    "limit_train_samples": 0,
    "limit_val_samples": 0,
    "limit_test_samples": 0
  },
  "optuna": {
    "direction": "minimize",
    "n_trials": 20,
    "timeout": null,
    "epochs_per_trial": 5
  }
}