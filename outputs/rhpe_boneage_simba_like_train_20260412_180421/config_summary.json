{
  "experiment_mode": "simba",
  "model_type": "SingleBackboneModel(resnet18)",
  "metadata_mode": "simba_multiplier",
  "metadata_inputs": "male, chronological",
  "input_modalities": [
    "grayscale_global_image",
    "global_roi_heatmap",
    "male",
    "chronological"
  ],
  "target_type": "relative_age = Boneage - Chronological -> final_boneage = Chronological + predicted_relative_age",
  "dataset_size": {
    "train": 5491,
    "val": 713,
    "test": 79
  },
  "device": "cuda:0",
  "structure": {
    "ensemble_mode": "resnet",
    "resnet_name": "resnet18",
    "efficientnet_name": "efficientnet_b0",
    "pretrained": false,
    "branch_mode": "global_only",
    "local_branch_mode": "patch_heatmap",
    "target_mode": "relative",
    "relative_target_direction": "boneage_minus_chronological",
    "metadata_enabled": true,
    "metadata_mode": "simba_multiplier",
    "metadata_use_gender": true,
    "metadata_use_chronological": true,
    "heatmap_guidance": true,
    "cbam_enabled": false,
    "cbam_global": true,
    "cbam_local": true
  },
  "data_strategy": {
    "input_size": 500,
    "local_patch_size": 96,
    "global_crop_mode": "bbox",
    "global_crop_margin_ratio": 0.0,
    "heatmap_sigma_ratio": 0.0,
    "heatmap_sigma_min": 25.0,
    "normalization_source": "manual"
  },
  "optimization": {
    "epochs": 90,
    "batch_size": 17,
    "gradient_accumulation_steps": 1,
    "optimizer": "adam",
    "lr": 0.001,
    "weight_decay": 0.0,
    "scheduler": "plateau",
    "scheduler_factor": 0.8,
    "scheduler_patience": 2,
    "warmup_epochs": 0,
    "loss": "l1",
    "best_metric": "mad",
    "amp_requested": false,
    "compile_requested": false,
    "compile_mode": "reduce-overhead"
  },
  "augmentation": {
    "affine_p": 1.0,
    "rotation_limit": 20.0,
    "translate_limit": 0.2,
    "scale_limit": 0.2,
    "shear_limit": 0.0,
    "horizontal_flip": true,
    "horizontal_flip_p": 0.5,
    "use_noise": false,
    "noise_p": 0.12,
    "use_blur": false,
    "blur_p": 0.08
  },
  "normalization": {
    "mean": 0.0,
    "std": 1.0,
    "source": "manual"
  }
}